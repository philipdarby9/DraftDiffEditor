{
  "name": "draft-diff-editor",
  "version": "0.1.0",
  "private": true,
  "description": "A local writing editor for managing drafts, notes, comparisons, and a companion text export.",
  "author": "Philip Darby",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "desktop": "electron .",
    "desktop:dev": "electron .",
    "package:win": "electron-builder --win --x64",
    "package:linux": "electron-builder --linux tar.gz --x64",
    "package:linux:deb": "electron-builder --linux deb --x64",
    "package:linux:appimage": "electron-builder --linux AppImage --x64"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "com.philipdarby.draftdiffeditor",
    "productName": "Draft Diff Editor",
    "files": [
      "desktop/**/*",
      "public/**/*",
      "server.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "icon.png",
        "to": "icon.png"
      }
    ],
    "afterPack": "scripts/after-pack.js",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "icon.png",
      "category": "Office",
      "maintainer": "Philip Darby <draft-diff-editor@localhost>",
      "target": [
        "tar.gz",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "dictionary-en-gb": "^3.0.0",
    "nspell": "^2.1.5"
  }
}
